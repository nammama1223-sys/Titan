
-- Hoài Nam Hub | Titan Fishing

local ScreenGui = Instance.new("ScreenGui")
local Frame = Instance.new("Frame")
local UIListLayout = Instance.new("UIListLayout")

ScreenGui.Parent = game.CoreGui
ScreenGui.Name = "HoaiNamHub"

Frame.Parent = ScreenGui
Frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
Frame.Position = UDim2.new(0.05,0,0.3,0)
Frame.Size = UDim2.new(0,180,0,200)

UIListLayout.Parent = Frame

local function Button(text,callback)
    local TextButton = Instance.new("TextButton")
    TextButton.Parent = Frame
    TextButton.Size = UDim2.new(1,0,0,30)
    TextButton.Text = text
    TextButton.BackgroundColor3 = Color3.fromRGB(50,50,50)
    TextButton.TextColor3 = Color3.new(1,1,1)

    TextButton.MouseButton1Click:Connect(callback)
end

-- Auto Fish
Button("🎣 Auto Fish",function()
    _G.AutoFish = not _G.AutoFish
    while _G.AutoFish do
        game:GetService("ReplicatedStorage").Events.Fish:FireServer()
        task.wait(1)
    end
end)

-- Auto Skill
Button("⚡ Auto Skill",function()
    _G.AutoSkill = not _G.AutoSkill
    while _G.AutoSkill do
        local v = game:GetService("VirtualInputManager")
        v:SendKeyEvent(true,"Z",false,game)
        v:SendKeyEvent(true,"X",false,game)
        v:SendKeyEvent(true,"C",false,game)
        v:SendKeyEvent(true,"V",false,game)
        task.wait(2)
    end
end)

-- Auto Sell
Button("💰 Auto Sell",function()
    game:GetService("ReplicatedStorage").Events.Sell:FireServer()
end)

-- Teleport Island
Button("🗺 Teleport Island",function()
    game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame =
    CFrame.new(0,10,0)
end)
